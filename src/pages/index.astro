---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

// Featured projects for carousel
const featuredProjects = projects.filter(p => p.featured);

// Recent blog posts (latest 3)
const postModules = import.meta.glob('../content/blog/*.md', { eager: true });
const allPosts = Object.values(postModules) as any[];
const recentPosts = allPosts
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="hero section">
    <div class="container container--wide">
      <div class="hero-intro">
        <div class="hero-top">
          <div class="hero-text">
            <span class="hero-greeting">Hi, I'm</span>
            <h1 class="hero-name">Daniel Wu<span class="hero-dot">.</span></h1>
            <p class="hero-tagline">
              CS student at UCLA. I build things, break things,
              and write about stuff. I dabble with music sometimes.
            </p>
          </div>
          <div class="hero-photo">
            <img src="/daniel_wu.jpg" alt="Daniel Wu" class="hero-photo__img" />
          </div>
        </div>
        <div class="hero-cta">
          <a href="/projects" class="btn btn--primary">View Projects</a>
          <a href="/contact" class="btn">Get in Touch</a>
        </div>
      </div>

      <div class="hero-terminal">
        <div class="terminal">
          <div class="terminal-header">
            <span class="terminal-dot terminal-dot--red"></span>
            <span class="terminal-dot terminal-dot--yellow"></span>
            <span class="terminal-dot terminal-dot--green"></span>
            <span class="terminal-title">~/.portfolio</span>
          </div>
          <div class="terminal-body" id="terminal-body">
            <div class="terminal-line">
              <span class="terminal-prompt">$</span>
              <span class="terminal-text" id="terminal-text"></span>
              <span class="terminal-cursor">|</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about section section--tight">
    <div class="container">
      <h2 class="section-heading">About Me</h2>
      <div class="about-content">
        <p>
          I'm a freshman studying Computer Science at UCLA with a passion for
          cybersecurity and building software that matters. When I'm not in class,
          you'll find me working on side projects, digging into security research,
          or making music.
        </p>
        <p>
          I believe in learning by doing, and every project is an opportunity to
          explore new technologies and push my boundaries. This site is a living
          portfolio of that journey.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Projects Carousel -->
  {featuredProjects.length > 0 && (
    <section class="featured section section--tight">
      <div class="container">
        <div class="featured-header">
          <h2 class="section-heading">Featured Projects</h2>
          <a href="/projects" class="featured-all">All projects &rarr;</a>
        </div>
        <div class="carousel">
          <button class="carousel-arrow carousel-arrow--prev" id="carousel-prev" aria-label="Previous">&larr;</button>
          <div class="carousel-viewport">
            <div class="carousel-track" id="carousel-track">
            {featuredProjects.map(project => (
              <div class="carousel-slide">
                <div class="card project-card project-card--featured">
                  <div class="project-card__header">
                    <h3 class="card__title">{project.title}</h3>
                    <span class="badge badge--accent">Featured</span>
                  </div>
                  <p class="card__description">{project.description}</p>
                  <div class="card__tags">
                    {project.tags.map(tag => <span class="badge">{tag}</span>)}
                  </div>
                  <div class="project-card__links">
                    {project.github && (
                      <a href={project.github} class="project-link" target="_blank" rel="noopener">
                        GitHub &nearr;
                      </a>
                    )}
                    {project.link && project.link !== '#' && (
                      <a href={project.link} class="project-link" target="_blank" rel="noopener">
                        Live Demo &nearr;
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))}
            </div>
          </div>
          <button class="carousel-arrow carousel-arrow--next" id="carousel-next" aria-label="Next">&rarr;</button>
        </div>
        <div class="carousel-dots" id="carousel-dots">
          {featuredProjects.map((_, i) => (
            <button class="carousel-dot" data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Recent Posts Preview -->
  <section class="recent section">
    <div class="container">
      <div class="recent-header">
        <h2 class="section-heading">Recent Writing</h2>
        <a href="/blog" class="featured-all">View all &rarr;</a>
      </div>
      <p class="recent-sub">Blog posts, writeups, and things I've learned along the way.</p>

      {recentPosts.length > 0 ? (
        <div class="recent-posts">
          {recentPosts.map(post => (
            <a href={`/blog/${post.frontmatter.slug}`} class="post-item card">
              <div class="post-item__meta">
                <time datetime={post.frontmatter.date}>
                  {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h3 class="post-item__title">{post.frontmatter.title}</h3>
              {post.frontmatter.description && (
                <p class="post-item__desc">{post.frontmatter.description}</p>
              )}
              {post.frontmatter.tags && (
                <div class="card__tags">
                  {post.frontmatter.tags.slice(0, 3).map((tag: string) => (
                    <span class="badge">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      ) : (
        <p class="recent-empty">No posts yet. Check back soon!</p>
      )}
    </div>
  </section>

  <!-- Skills Section -->
  <section class="skills section">
    <div class="container">
      <h2 class="section-heading">What I Work With</h2>
      <div class="skills-grid">
        <div class="skill-group">
          <h4 class="skill-group__title">Languages</h4>
          <div class="skill-tags">
            <span class="badge badge--accent">Python</span>
            <span class="badge badge--accent">C++</span>
            <span class="badge badge--accent">JavaScript</span>
            <span class="badge badge--accent">Swift</span>
            <span class="badge badge--accent">SQL</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-group__title">Security</h4>
          <div class="skill-tags">
            <span class="badge badge--orange">Pen Testing</span>
            <span class="badge badge--orange">Cryptography</span>
            <span class="badge badge--orange">Wireshark</span>
            <span class="badge badge--orange">nmap</span>
            <span class="badge badge--orange">ICS/OT</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-group__title">Frameworks</h4>
          <div class="skill-tags">
            <span class="badge badge--emerald">React</span>
            <span class="badge badge--emerald">Node.js</span>
            <span class="badge badge--emerald">Flask</span>
            <span class="badge badge--emerald">FastAPI</span>
            <span class="badge badge--emerald">SwiftUI</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-group__title">Tools & Infra</h4>
          <div class="skill-tags">
            <span class="badge badge--emerald">Linux</span>
            <span class="badge badge--emerald">Git</span>
            <span class="badge badge--emerald">Docker</span>
            <span class="badge badge--emerald">Bash</span>
          </div>
        </div>
        <div class="skill-group">
          <h4 class="skill-group__title">Data & ML</h4>
          <div class="skill-tags">
            <span class="badge badge--violet">TensorFlow</span>
            <span class="badge badge--violet">OpenCV</span>
            <span class="badge badge--violet">pandas</span>
            <span class="badge badge--violet">scikit-learn</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Music Player Widget -->
  <section class="music section">
    <div class="container">
      <h2 class="section-heading">In the Studio</h2>
      <p class="music-sub">
        A few tracks I've been working on lately.
      </p>
      <div class="music-card">
        <iframe
          title="SYR3N on Spotify"
          src="https://open.spotify.com/embed/artist/0sStTpewAdWD6kKrWSFZqX?utm_source=generator&theme=0"
          width="100%"
          height="352"
          frameborder="0"
          allowfullscreen
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Now Section -->
  <section class="now section">
    <div class="container">
      <div class="now-header">
        <h2 class="section-heading">/now</h2>
        <span class="now-status">
          <span class="now-status__dot"></span>
          Last updated April 2026
        </span>
      </div>
      <p class="now-sub">A snapshot of what I'm up to right now.</p>
      <div class="now-grid">
        <div class="now-card now-card--blue">
          <span class="now-card__icon">&#127891;</span>
          <span class="now-card__label">Studying</span>
          <p class="now-card__value">Freshman year @ UCLA — Spring 2026 quarter</p>
        </div>
        <div class="now-card now-card--emerald">
          <span class="now-card__icon">&#128736;</span>
          <span class="now-card__label">Building</span>
          <p class="now-card__value">This site, plus a couple of security side projects</p>
        </div>
        <div class="now-card now-card--orange">
          <span class="now-card__icon">&#128218;</span>
          <span class="now-card__label">Learning</span>
          <p class="now-card__value">Reverse engineering and ICS/OT security</p>
        </div>
        <div class="now-card now-card--violet">
          <span class="now-card__icon">&#127911;</span>
          <span class="now-card__label">Listening to</span>
          <p class="now-card__value">Progressive House and Dubstep, and the occasional indie track</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="cta section">
    <div class="container">
      <div class="cta-card">
        <h2 class="cta-title">
          Let's <span class="cta-title__accent">build something</span>.
        </h2>
        <p class="cta-text">
          Got a project idea, an internship opportunity, or just want to say hi?
          I reply to every message — usually within a day.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn--primary cta-btn-primary">
            Get in Touch
            <span class="cta-arrow">&rarr;</span>
          </a>
          <a href="/resume" class="btn">View Resume</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Terminal typing effect
  const commands = [
    { text: 'whoami', delay: 80 },
    { text: 'cat interests.txt', delay: 60 },
    { text: 'ls projects/', delay: 70 },
    { text: 'echo "Welcome to my website!"', delay: 50 },
  ];

  const responses: Record<string, string> = {
    'whoami': 'daniel_wu @ UCLA',
    'cat interests.txt': 'cybersecurity, web dev, machine learning, music production',
    'ls projects/': 'coming_soon/  in_progress/  completed/',
    'echo "Welcome to my website!"': 'Welcome to my website!',
  };

  const terminalBody = document.getElementById('terminal-body');
  let activeText: Element | null = document.getElementById('terminal-text');

  async function typeCommand(cmd: typeof commands[0]) {
    if (!activeText) return;

    for (let i = 0; i < cmd.text.length; i++) {
      activeText.textContent = cmd.text.slice(0, i + 1);
      await new Promise(r => setTimeout(r, cmd.delay + Math.random() * 40));
    }

    await new Promise(r => setTimeout(r, 400));

    if (terminalBody) {
      const cursor = terminalBody.querySelector('.terminal-cursor');
      cursor?.remove();

      const responseLine = document.createElement('div');
      responseLine.className = 'terminal-line terminal-response';
      responseLine.textContent = responses[cmd.text] || '';
      terminalBody.appendChild(responseLine);

      await new Promise(r => setTimeout(r, 600));
    }
  }

  async function runTerminal() {
    while (true) {
      // Reset terminal to initial state
      if (terminalBody) {
        terminalBody.innerHTML = `<div class="terminal-line"><span class="terminal-prompt">$</span><span class="terminal-text"></span><span class="terminal-cursor">|</span></div>`;
        activeText = terminalBody.querySelector('.terminal-text');
      }

      for (const cmd of commands) {
        await typeCommand(cmd);

        if (terminalBody) {
          const newLine = document.createElement('div');
          newLine.className = 'terminal-line';
          newLine.innerHTML = `<span class="terminal-prompt">$</span><span class="terminal-text"></span><span class="terminal-cursor">|</span>`;
          terminalBody.appendChild(newLine);
          terminalBody.scrollTop = terminalBody.scrollHeight;

          activeText = newLine.querySelector('.terminal-text');
        }

        await new Promise(r => setTimeout(r, 800));
      }

      // Pause before restarting
      await new Promise(r => setTimeout(r, 3000));
    }
  }

  // Use intersection observer to start animation when visible
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        runTerminal();
        observer.disconnect();
      }
    });
  });

  if (terminalBody) observer.observe(terminalBody);

  // Featured Projects Carousel
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const dotsContainer = document.getElementById('carousel-dots');
  const slides = track ? Array.from(track.querySelectorAll('.carousel-slide')) : [];
  let currentSlide = 0;

  function updateCarousel() {
    if (!track) return;
    track.style.transform = `translateX(-${currentSlide * 100}%)`;
    if (dotsContainer) {
      dotsContainer.querySelectorAll('.carousel-dot').forEach((dot, i) => {
        dot.classList.toggle('active', i === currentSlide);
      });
    }
  }

  function goTo(i: number) {
    if (slides.length === 0) return;
    currentSlide = (i + slides.length) % slides.length;
    updateCarousel();
  }

  prevBtn?.addEventListener('click', () => goTo(currentSlide - 1));
  nextBtn?.addEventListener('click', () => goTo(currentSlide + 1));
  dotsContainer?.querySelectorAll('.carousel-dot').forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  // Auto-advance carousel
  if (slides.length > 1) {
    updateCarousel();
    setInterval(() => goTo(currentSlide + 1), 6000);
  }
</script>

<style>
  /* Compact spacing for stacked About / Featured / Now sections */
  .section--tight {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .section + .section--tight {
    padding-top: 0;
  }

  .section--tight .section-heading {
    margin-bottom: var(--space-md);
  }

  /* Hero */
  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero-top {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .hero-text {
    flex: 1;
  }

  .hero-photo {
    flex-shrink: 0;
  }

  .hero-photo__placeholder {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--bg-secondary);
    border: 3px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-photo__initials {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-tertiary);
  }

  .hero-photo__img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--border);
  }

  .hero-greeting {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--accent-blue);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .hero-name {
    margin-bottom: var(--space-md);
  }

  .hero-dot {
    color: var(--accent-blue);
  }

  .hero-tagline {
    font-size: 1.125rem;
    max-width: 40ch;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Terminal */
  .terminal {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-light);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot--red { background: #ef4444; }
  .terminal-dot--yellow { background: #eab308; }
  .terminal-dot--green { background: #22c55e; }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-left: 8px;
  }

  .terminal-body {
    padding: 14px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.8;
    min-height: 280px;
    max-height: 400px;
    overflow-y: auto;
  }

  .terminal-line {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .terminal-prompt {
    color: var(--accent-emerald);
    font-weight: 600;
    flex-shrink: 0;
  }

  .terminal-text {
    color: var(--text-primary);
  }

  .terminal-cursor {
    color: var(--accent-blue);
    animation: cursorBlink 1s step-end infinite;
  }

  @keyframes cursorBlink {
    50% { opacity: 0; }
  }

  :global(.terminal-response) {
    color: var(--accent-blue) !important;
    padding-left: 18px;
    opacity: 0.8;
  }

  /* About */
  .section-heading {
    margin-bottom: var(--space-xl);
    position: relative;
    display: inline-block;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--accent-blue);
    border-radius: 2px;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about-content p {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-xl);
  }

  .skill-group__title {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* Featured Projects Carousel */
  .featured-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .featured-all {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
  }

  .featured-all:hover {
    color: var(--accent-blue);
  }

  .carousel {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .carousel-viewport {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .carousel-track {
    display: flex;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .carousel-slide {
    flex: 0 0 100%;
    min-width: 0;
    padding: var(--space-xs);
  }

  .carousel-arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    cursor: pointer;
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-arrow:hover {
    background: var(--accent-blue);
    color: white;
    border-color: var(--accent-blue);
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--border);
    padding: 0;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .carousel-dot.active {
    background: var(--accent-blue);
    transform: scale(1.3);
  }

  /* Now Section */
  .now-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .now-header .section-heading {
    margin-bottom: 0;
  }

  .now-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    padding: var(--space-xs) var(--space-md);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
  }

  .now-status__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-emerald);
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.6);
    animation: nowPulse 2s ease-out infinite;
  }

  @keyframes nowPulse {
    0%   { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.6); }
    70%  { box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  .now-sub {
    margin-top: 0;
    margin-bottom: var(--space-xl);
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .now-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-lg);
  }

  .now-card {
    position: relative;
    padding: var(--space-lg);
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
